# Which AI vendor to use: "groq" (default, free, no billing card required) or "gemini".
AI_PROVIDER=groq

# Get a free Groq API key at https://console.groq.com/keys (no billing card required).
GROQ_API_KEY=

# Optional: only needed if AI_PROVIDER=gemini. https://aistudio.google.com/apikey
GEMINI_API_KEY=

PORT=4000
NODE_ENV=development

# Comma-separated list of allowed origins for CORS, or * for any origin.
CORS_ORIGIN=*

# Number of CSV rows sent to the AI per request.
BATCH_SIZE=40
# Number of batches processed concurrently.
BATCH_CONCURRENCY=2
# Max upload size in bytes (default 5MB).
MAX_UPLOAD_BYTES=5242880
